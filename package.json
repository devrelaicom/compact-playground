{
  "name": "compact-playground",
  "version": "1.0.0",
  "description": "Compile Compact smart contracts in the browser",
  "type": "module",
  "scripts": {
    "dev:node": "tsx watch backend/src/index.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --check \"backend/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\"",
    "format:fix": "prettier --write \"backend/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\"",
    "typecheck": "tsc --noEmit",
    "quality": "npm run lint && npm run format && npm run typecheck && npm run test:run"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
