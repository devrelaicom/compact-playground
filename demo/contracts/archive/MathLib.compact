module MathLib {
  pragma language_version >= 0.21;

  import CompactStandardLibrary;

  export circuit add(a: Uint<64>, b: Uint<64>): Uint<64> {
    return (a + b) as Uint<64>;
  }

  export circuit subtract(a: Uint<64>, b: Uint<64>): Uint<64> {
    assert(a >= b, "Underflow");
    return (a - b) as Uint<64>;
  }
}
