pragma language_version >= 0.21;

import CompactStandardLibrary;
import MathLib;

export ledger vaultBalance: Uint<64>;

export circuit deposit(amount: Uint<64>): [] {
  vaultBalance = MathLib.add(vaultBalance, amount);
}

export circuit withdraw(amount: Uint<64>): [] {
  vaultBalance = MathLib.subtract(vaultBalance, amount);
}

export circuit getVaultBalance(): Uint<64> {
  return vaultBalance;
}
